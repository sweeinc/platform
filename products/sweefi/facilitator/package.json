{
  "name": "@sweefi/facilitator",
  "version": "0.2.0",
  "type": "module",
  "description": "Self-hostable s402 payment verification and settlement service for SweeFi — runnable as `npx @sweefi/facilitator start`",
  "keywords": [
    "sui",
    "solana",
    "s402",
    "http-402",
    "payment",
    "web3",
    "ai-agent",
    "defi",
    "micropayments",
    "agentic-commerce",
    "facilitator",
    "cli"
  ],
  "homepage": "https://sweefi.xyz",
  "bugs": {
    "url": "https://github.com/sweeinc/platform/issues"
  },
  "license": "Apache-2.0",
  "author": "Danny Devs",
  "repository": {
    "type": "git",
    "url": "https://github.com/sweeinc/platform.git",
    "directory": "products/sweefi/facilitator"
  },
  "bin": {
    "sweefi-facilitator": "./dist/cli.mjs"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./app": {
      "import": {
        "types": "./dist/app.d.mts",
        "default": "./dist/app.mjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsdown",
    "start": "node dist/cli.mjs start",
    "dev": "tsx --env-file=.env src/cli.ts start",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build && pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "@hono/node-server": "^1.8.0",
    "@mysten/sui": "^2.6.0",
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.95.0",
    "@sweefi/solana": "workspace:^",
    "@sweefi/sui": "workspace:^",
    "hono": "^4.12.15",
    "s402": "^0.5.0",
    "sui-gas-station": "^0.2.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "tsdown": "^0.21.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.2.6",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5"
  }
}
