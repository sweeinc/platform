# ── Required ───────────────────────────────────
# Comma-separated API keys (each must be ≥16 characters)
API_KEYS=your-api-key-here-min-16-chars

# ── Fees ──────────────────────────────────────
# Fee in micro-percent (1,000,000 = 100%). Default: 5000 (0.5%)
# FEE_MICRO_PERCENT=5000

# Sui address that receives protocol fees (shown in /.well-known/s402-facilitator)
# FEE_RECIPIENT=0x...

# ── Anti-Spoofing ─────────────────────────────
# SweeFi Move package ID for event verification. Required for non-exact schemes.
# Without this, only the "exact" scheme is registered.
# SWEEFI_PACKAGE_ID=0x...

# ── Server ────────────────────────────────────
# PORT=4022
# LOG_LEVEL=info  # debug | info | warn | error

# ── Sui RPC (optional overrides) ──────────────
# SUI_MAINNET_RPC=https://fullnode.mainnet.sui.io:443
# SUI_TESTNET_RPC=https://fullnode.testnet.sui.io:443

# ── Solana RPC (optional overrides) ───────────
# SOLANA_MAINNET_RPC=https://api.mainnet-beta.solana.com
# SOLANA_DEVNET_RPC=https://api.devnet.solana.com

# ── Solana Program IDs (optional) ─────────────
# For mainnet deployment, set these to your mainnet program addresses.
# Defaults to devnet program IDs if not set.
# SOLANA_PREPAID_PROGRAM_ID=FsdmgrStNw43ib6UXL4CPJ2cPHXwoSiGoMAYKppcgAxC
# SOLANA_STREAM_PROGRAM_ID=HMTeFyU4yXf7QB3D1WE7vQqPrZSecmeD1f5gqCauDL7M
# SOLANA_ESCROW_PROGRAM_ID=AbH1dHyrGjE8P6Ti4QLSWp9zVzZZfAg26uK5DqLY12Gt
# SOLANA_UPTO_PROGRAM_ID=7H1iJSgBnFC7fgVje5EjXHRQs9XHCFDpcFQ2aXHaovsD

# ── Gas Sponsorship (optional) ────────────────
# Base64-encoded Sui keypair for sponsoring agent transactions.
# Must be funded. Without this, gas sponsorship is disabled.
# FACILITATOR_KEYPAIR=suiprivkey1...

# Max gas budget per sponsored transaction in MIST (default: 10,000,000 = 0.01 SUI)
# MAX_SPONSOR_GAS_MIST=10000000

# Max sponsored transactions per API key per hour (default: 100, 0 = disabled)
# GAS_SPONSOR_MAX_PER_HOUR=100

# ── Rate Limiting ─────────────────────────────
# Token bucket: max tokens per key (default: 100)
# RATE_LIMIT_MAX_TOKENS=100

# Token bucket: refill rate per second (default: 10)
# RATE_LIMIT_REFILL_RATE=10
