{
  "name": "@sweefi/hono",
  "version": "0.2.1",
  "type": "module",
  "description": "Chain-agnostic s402 middleware and client fetch wrapper for Hono. Successor to @sweefi/server (renamed for honesty — this package IS the Hono middleware).",
  "keywords": [
    "sui",
    "s402",
    "http-402",
    "payment",
    "web3",
    "ai-agent",
    "defi",
    "micropayments",
    "agentic-commerce"
  ],
  "homepage": "https://sweefi.xyz",
  "bugs": {
    "url": "https://github.com/sweeinc/platform/issues"
  },
  "license": "Apache-2.0",
  "author": "Danny Devs",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client/index.d.mts",
        "default": "./dist/client/index.mjs"
      },
      "require": {
        "types": "./dist/client/index.d.cts",
        "default": "./dist/client/index.cjs"
      },
      "default": "./dist/client/index.mjs"
    },
    "./server": {
      "import": {
        "types": "./dist/server/index.d.mts",
        "default": "./dist/server/index.mjs"
      },
      "require": {
        "types": "./dist/server/index.d.cts",
        "default": "./dist/server/index.cjs"
      },
      "default": "./dist/server/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build && pnpm run typecheck && pnpm run test"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sweeinc/platform.git",
    "directory": "products/sweefi/hono"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "s402": "^0.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "hono": "^4.0.0",
    "tsdown": "^0.21.10",
    "typescript": "^5.7.3",
    "vite": "^6.2.6",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5"
  },
  "peerDependencies": {
    "hono": ">=4.0.0"
  }
}
